# OneMuseum configuration — copy to .env and fill in real values.
#
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed. Real values are passed to
# other developers by direct secure channel, never via the repo.
# Dev credentials are throwaway and must differ from production.

# --- Required: the app refuses to start without these ---

# Flask session signing / CSRF. Generate a fresh one per environment:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# MariaDB connection (the dev database runs in Docker; see docs/CONFIG.md).
MYSQLCONN_HOST=127.0.0.1
MYSQLCONN_PORT=3306
MYSQLCONN_USER=
MYSQLCONN_PASSWORD=
MYSQLCONN_DATABASE=onemuseum2

# Root password for the MariaDB container (used by docker-compose.yml).
# Only takes effect when the volume is first initialised.
MARIADB_ROOT_PASSWORD=

# --- Optional: mail features are disabled if unset ---
MAIL_SERVER=
MAIL_USERNAME=
MAIL_PASSWORD=
